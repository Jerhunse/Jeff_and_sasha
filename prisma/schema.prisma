generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model ActivityLog {
  id          String         @id
  coupleId    String
  actorId     String?
  action      ActivityAction
  entityType  String?
  entityId    String?
  description String
  meta        String?
  createdAt   DateTime       @default(now())
  user        User?          @relation(fields: [actorId], references: [id])
  couple      Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([actorId])
  @@index([coupleId])
  @@index([createdAt])
}

model Address {
  id        String      @id
  coupleId  String
  line1     String
  line2     String?
  city      String
  state     String
  postal    String
  country   String      @default("US")
  createdAt DateTime    @default(now())
  updatedAt DateTime
  couple    Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  guests    Guest[]
  households Household[]

  @@index([coupleId])
}

model Campaign {
  id              String         @id
  coupleId        String
  name            String
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  subject         String?
  templateId      String?
  customHTML      String?
  customText      String?
  smsMessage      String?
  segmentJSON     String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int            @default(0)
  sent            Int            @default(0)
  delivered       Int            @default(0)
  opened          Int            @default(0)
  clicked         Int            @default(0)
  bounced         Int            @default(0)
  failed          Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  couple          Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  invitations     Invitation[]

  @@index([coupleId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

model CashFund {
  id                   String                 @id
  coupleId             String
  title                String
  description          String?
  imageUrl             String?
  goal                 Float?
  received             Float                  @default(0)
  stripePriceId        String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  couple               Couple                 @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  contributions        CashFundContribution[]

  @@index([coupleId])
}

model CashFundContribution {
  id              String   @id
  cashFundId      String
  name            String
  email           String?
  message         String?
  amount          Float
  currency        String   @default("usd")
  stripePaymentId String?  @unique
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  cashFund        CashFund @relation(fields: [cashFundId], references: [id], onDelete: Cascade)

  @@index([cashFundId])
  @@index([stripePaymentId])
}

model ContactMessage {
  id         String   @id
  coupleId   String
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  isRead     Boolean  @default(false)
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@index([isRead])
}

model Couple {
  id                 String               @id
  slug               String               @unique
  partner1Name       String
  partner2Name       String
  weddingDate        DateTime
  venueName          String?
  venueAddress       String?
  venueCity          String?
  venueState         String?
  venueZip           String?
  venueCountry       String?
  primaryColor       String               @default("#6b9c7f")
  secondaryColor     String               @default("#f5f5f0")
  accentColor        String               @default("#d4a574")
  fontHeading        String               @default("Playfair Display")
  fontBody           String               @default("Inter")
  cornerRadius       String               @default("medium")
  showFlorals        Boolean              @default(true)
  heroImageUrl       String?
  logoImageUrl       String?
  privacyMode        PrivacyMode          @default(PUBLIC)
  sitePassword       String?
  isPublished        Boolean              @default(false)
  customDomain       String?
  allowPlusOnes      Boolean              @default(true)
  rsvpDeadline       DateTime?
  maxCapacity        Int?
  timezone           String               @default("America/New_York")
  stripeAccountId    String?
  googleMapsApiKey   String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  landingVideoUrl    String?
  askBusTransport    Boolean              @default(false)
  askMealChoice      Boolean              @default(false)
  askSongRequest     Boolean              @default(true)
  busRoutes          String?
  mealOptions        String?
  activityLogs       ActivityLog[]
  addresses          Address[]
  campaigns          Campaign[]
  cashFunds          CashFund[]
  contactMessages    ContactMessage[]
  events             Event[]
  faqs               Faq[]
  guests             Guest[]
  hotels             HotelBlock[]
  households         Household[]
  invitations        Invitation[]
  media              Media[]
  messages           Message[]
  pages              Page[]
  rsvpQuestions      RSVPQuestion[]
  rsvpResponses      RSVPResponse[]
  registryLinks      RegistryLink[]
  seatingCharts      SeatingChart[]
  tags               Tag[]
  users              User[]
  weddingParty       WeddingPartyMember[]

  @@index([customDomain])
  @@index([slug])
}

model Event {
  id           String          @id
  coupleId     String
  name         String
  description  String?
  startTime    DateTime
  endTime      DateTime?
  location     String?
  address      String?
  venue        String?
  attire       String?
  visibility   EventVisibility @default(PUBLIC)
  capacity     Int?
  order        Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime
  couple       Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  rsvpQuestions RSVPQuestion[]
  rsvpResponses RSVPResponse[]
  seatingCharts SeatingChart[]

  @@index([coupleId])
  @@index([startTime])
}

model Faq {
  id        String   @id
  coupleId  String
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model Guest {
  id               String          @id
  coupleId         String
  userId           String?         @unique
  firstName        String
  lastName         String
  email            String?
  phone            String?
  addressId        String?
  householdId      String?
  isPrimaryContact Boolean         @default(true)
  relationship     String?
  age              Int?
  isChild          Boolean         @default(false)
  isVIP            Boolean         @default(false)
  doNotContact     Boolean         @default(false)
  inviteToken      String          @unique
  invitedBy        String?
  allowPlusOne     Boolean         @default(false)
  plusOnePolicy    String          @default("none")
  importSource     String?
  importedAt       DateTime?
  originalData     String?
  notes            String?
  importance       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  maxGuestsAllowed Int             @default(1)
  address          Address?        @relation(fields: [addressId], references: [id])
  couple           Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  household        Household?      @relation(fields: [householdId], references: [id])
  user             User?           @relation(fields: [userId], references: [id])
  activities       GuestActivity[]
  tags             GuestTag[]
  invitations      Invitation[]
  rsvpResponses    RSVPResponse[]
  seats            Seat[]

  @@index([addressId])
  @@index([coupleId])
  @@index([email])
  @@index([householdId])
  @@index([inviteToken])
  @@index([lastName])
}

model GuestActivity {
  id          String         @id
  guestId     String
  action      ActivityAction
  description String
  changes     String?
  userId      String?
  userName    String?
  canUndo     Boolean        @default(false)
  undoData    String?
  undoneAt    DateTime?
  undoneBy    String?
  createdAt   DateTime       @default(now())
  guest       Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([createdAt])
  @@index([guestId])
}

model GuestTag {
  id      String   @id
  guestId String
  tagId   String
  addedAt DateTime @default(now())
  addedBy String?
  guest   Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([guestId, tagId])
  @@index([guestId])
  @@index([tagId])
}

model HotelBlock {
  id                String    @id
  coupleId          String
  name              String
  description       String?
  address           String?
  city              String?
  state             String?
  zip               String?
  phone             String?
  website           String?
  code              String?
  startDate         DateTime?
  endDate           DateTime?
  deadline          DateTime?
  specialRate       String?
  mapPin            String?
  distanceFromVenue String?
  amenities         String?
  order             Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  imageUrl          String?
  couple            Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model Household {
  id        String   @id
  coupleId  String
  name      String
  addressId String?
  maxGuests Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  guests    Guest[]
  address   Address? @relation(fields: [addressId], references: [id])
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([coupleId])
}

model Invitation {
  id             String           @id
  coupleId       String
  campaignId     String?
  guestId        String
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  sentViaEmail   Boolean          @default(false)
  sentViaSMS     Boolean          @default(false)
  emailAddress   String?
  phoneNumber    String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  repliedAt      DateTime?
  unsubscribedAt DateTime?
  openCount      Int              @default(0)
  clickCount     Int              @default(0)
  errorMessage   String?
  metadata       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  campaign       Campaign?        @relation(fields: [campaignId], references: [id])
  couple         Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  guest          Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([campaignId, guestId])
  @@index([campaignId])
  @@index([coupleId])
  @@index([guestId])
  @@index([status])
  @@index([token])
}

model Media {
  id           String   @id
  coupleId     String
  url          String
  thumbnailUrl String?
  filename     String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  caption      String?
  tags         String[]
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  couple       Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@index([tags])
}

model Message {
  id              String        @id
  coupleId        String
  subject         String
  bodyHTML        String
  bodyText        String?
  segmentJSON     String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  status          MessageStatus @default(DRAFT)
  totalRecipients Int           @default(0)
  sent            Int           @default(0)
  delivered       Int           @default(0)
  opened          Int           @default(0)
  failed          Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  couple          Couple        @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
  @@index([scheduledAt])
  @@index([status])
}

model Page {
  id          String   @id
  coupleId    String
  type        PageType
  slug        String
  title       String
  contentJSON String
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  pageSEO     PageSEO?

  @@unique([coupleId, slug])
  @@index([coupleId])
  @@index([type])
}

model PageSEO {
  id              String   @id
  pageId          String   @unique
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model RSVPQuestion {
  id             String       @id
  coupleId       String
  eventId        String?
  text           String
  description    String?
  type           QuestionType
  options        String[]
  placeholder    String?
  required       Boolean      @default(false)
  order          Int          @default(0)
  visibilityRule String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  couple         Couple       @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id])

  @@index([coupleId])
  @@index([eventId])
  @@index([order])
}

model RSVPResponse {
  id             String     @id
  coupleId       String
  guestId        String
  eventId        String?
  status         RsvpStatus @default(PENDING)
  answersJSON    String?
  message        String?
  plusOneName    String?
  plusOneEmail   String?
  plusOneAnswers String?
  respondedAt    DateTime   @default(now())
  updatedAt      DateTime
  couple         Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  event          Event?     @relation(fields: [eventId], references: [id])
  guest          Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([guestId, eventId])
  @@index([coupleId])
  @@index([eventId])
  @@index([guestId])
  @@index([status])
}

model RegistryLink {
  id          String   @id
  coupleId    String
  label       String
  url         String
  description String?
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model Seat {
  id         String   @id
  tableId    String
  guestId    String
  seatNumber Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  guest      Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  table      Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, guestId])
  @@index([guestId])
  @@index([tableId])
}

model SeatingChart {
  id          String   @id
  coupleId    String
  eventId     String?
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id])
  tables      Table[]

  @@index([coupleId])
  @@index([eventId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Table {
  id             String       @id
  seatingChartId String
  name           String
  capacity       Int
  shape          String?
  x              Float?
  y              Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  seats          Seat[]
  seatingChart   SeatingChart @relation(fields: [seatingChartId], references: [id], onDelete: Cascade)

  @@index([seatingChartId])
}

model Tag {
  id          String     @id
  coupleId    String
  name        String
  color       String     @default("#6b9c7f")
  description String?
  icon        String?
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  guests      GuestTag[]
  couple      Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([coupleId, name])
  @@index([coupleId])
}

model User {
  id            String        @id
  email         String        @unique
  name          String?
  image         String?
  role          Role          @default(GUEST)
  emailVerified DateTime?
  coupleId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  accounts      Account[]
  activityLogs  ActivityLog[]
  guest         Guest?
  sessions      Session[]
  couple        Couple?       @relation(fields: [coupleId], references: [id])

  @@index([coupleId])
  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WeddingPartyMember {
  id           String           @id
  coupleId     String
  name         String
  role         WeddingPartyRole
  roleLabel    String?
  bio          String?
  imageUrl     String?
  relationship String?
  order        Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime
  couple       Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  IMPORTED
  MERGED
  TAG_ADDED
  TAG_REMOVED
  RSVP_CHANGED
  INVITE_SENT
  NOTE_ADDED
  BULK_UPDATED
  MESSAGE_SENT
  SEATING_UPDATED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum CampaignType {
  SAVE_THE_DATE
  INVITATION
  REMINDER
  UPDATE
  THANK_YOU
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum InvitationStatus {
  PENDING
  SCHEDULED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum PageType {
  HOME
  STORY
  SCHEDULE
  TRAVEL
  REGISTRY
  FAQ
  GALLERY
  PARTY
  CONTACT
  CUSTOM
}

enum PrivacyMode {
  PUBLIC
  PASSWORD
  INVITE_ONLY
}

enum QuestionType {
  TEXT
  TEXTAREA
  SINGLE_SELECT
  MULTI_SELECT
  YES_NO
  MEAL_CHOICE
  DIETARY
  PLUS_ONE
  NUMBER
  DATE
  EMAIL
  PHONE
}

enum Role {
  OWNER
  COLLABORATOR
  VENDOR
  GUEST
}

enum RsvpStatus {
  PENDING
  YES
  NO
  MAYBE
}

enum WeddingPartyRole {
  BRIDE
  GROOM
  BRIDESMAID
  GROOMSMAN
  MAID_OF_HONOR
  BEST_MAN
  OFFICIANT
  FLOWER_GIRL
  RING_BEARER
  USHER
  READER
  OTHER
}
