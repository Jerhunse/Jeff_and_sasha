// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Authentication & User Management
// ============================================

enum Role {
  OWNER        // Couple getting married
  COLLABORATOR // Helpers (parents, wedding planner)
  VENDOR       // Photographers, caterers, etc.
  GUEST        // Wedding guests
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          Role      @default(GUEST)
  
  // Auth
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  
  // Relations
  weddingId     String?
  wedding       Wedding?  @relation(fields: [weddingId], references: [id])
  
  guestProfile  Guest?
  rsvpResponses RsvpResponse[]
  messages      Message[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([email])
  @@index([weddingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Wedding Core
// ============================================

model Wedding {
  id          String   @id @default(cuid())
  slug        String   @unique // URL slug (e.g., "jeff-and-sasha")
  
  // Basic Info
  partner1Name    String
  partner2Name    String
  weddingDate     DateTime
  venueName       String?
  venueAddress    String?
  venueCity       String?
  venueState      String?
  venueZip        String?
  
  // Theme & Branding
  primaryColor    String @default("#6b9c7f")
  secondaryColor  String @default("#f5f5f0")
  heroImageUrl    String?
  logoImageUrl    String?
  
  // Settings
  isPublished     Boolean @default(false)
  allowPlusOnes   Boolean @default(true)
  rsvpDeadline    DateTime?
  
  // Relations
  users           User[]
  guests          Guest[]
  pages           Page[]
  events          Event[]
  rsvpResponses   RsvpResponse[]
  hotels          Hotel[]
  registry        RegistryItem[]
  faqs            Faq[]
  gallery         GalleryImage[]
  messages        Message[]
  seatingCharts   SeatingChart[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([slug])
}

// ============================================
// CMS - Pages & Content
// ============================================

model Page {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  slug        String   // e.g., "our-story", "travel", "schedule"
  title       String
  content     String?  // Rich text JSON or markdown
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  
  sections    Section[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([weddingId, slug])
  @@index([weddingId])
}

model Section {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  type        String   // hero, text, image, gallery, timeline, etc.
  content     String   // JSON content for the section
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([pageId])
}

model GalleryImage {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  url         String
  caption     String?
  altText     String?
  order       Int      @default(0)
  category    String?  // engagement, ceremony, reception, etc.
  
  createdAt   DateTime @default(now())
  
  @@index([weddingId])
}

// ============================================
// Events & Schedule
// ============================================

model Event {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  location    String?
  address     String?
  attire      String?  // Formal, Semi-formal, Casual, etc.
  
  // Guest Management
  isPublic    Boolean  @default(true) // Some events might be private
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([weddingId])
}

// ============================================
// Guest Management & RSVP
// ============================================

enum RsvpStatus {
  PENDING
  ATTENDING
  DECLINED
  MAYBE
}

model Guest {
  id              String   @id @default(cuid())
  weddingId       String
  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  
  // Guest Info
  firstName       String
  lastName        String
  email           String?
  phone           String?
  
  // Invitation
  inviteCode      String   @unique // Unique code for RSVP link
  inviteSent      DateTime?
  inviteViewed    DateTime?
  
  // Plus One
  allowPlusOne    Boolean  @default(false)
  plusOneName     String?
  plusOneEmail    String?
  
  // Group (for families)
  groupName       String?
  
  // RSVP
  rsvpStatus      RsvpStatus @default(PENDING)
  rsvpDate        DateTime?
  
  // Dietary & Preferences
  dietaryRestrictions String?
  mealChoice          String?
  songRequest         String?
  specialNeeds        String?
  
  // Travel
  needsAccommodation  Boolean @default(false)
  
  // Relations
  rsvpResponses   RsvpResponse[]
  seatingAssignment SeatingAssignment?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([weddingId])
  @@index([inviteCode])
  @@index([email])
}

model RsvpResponse {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  guestId     String
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Response details
  status      RsvpStatus
  message     String?
  
  // Event-specific (if tracking per event)
  eventId     String?
  
  respondedAt DateTime @default(now())
  
  @@index([weddingId])
  @@index([guestId])
}

// ============================================
// Seating Arrangements
// ============================================

model SeatingChart {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  name        String   // e.g., "Reception", "Ceremony"
  description String?
  
  tables      Table[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([weddingId])
}

model Table {
  id              String   @id @default(cuid())
  seatingChartId  String
  seatingChart    SeatingChart @relation(fields: [seatingChartId], references: [id], onDelete: Cascade)
  
  name            String   // e.g., "Table 1", "Head Table"
  capacity        Int
  shape           String?  // round, rectangle, etc.
  
  assignments     SeatingAssignment[]
  
  @@index([seatingChartId])
}

model SeatingAssignment {
  id          String   @id @default(cuid())
  tableId     String
  table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  
  guestId     String   @unique
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  seatNumber  Int?
  
  @@index([tableId])
}

// ============================================
// Hotels & Travel
// ============================================

model Hotel {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  name        String
  address     String
  city        String
  state       String
  zip         String
  phone       String?
  website     String?
  
  // Room Block
  blockCode   String?
  blockDeadline DateTime?
  specialRate String?
  
  distanceFromVenue String?
  amenities         String?
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([weddingId])
}

// ============================================
// Registry
// ============================================

model RegistryItem {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  url         String
  storeName   String?
  imageUrl    String?
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([weddingId])
}

// ============================================
// FAQs
// ============================================

model Faq {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  question    String
  answer      String
  category    String?
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([weddingId])
}

// ============================================
// Messages & Guestbook
// ============================================

model Message {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  name        String
  email       String?
  message     String
  
  isApproved  Boolean  @default(false) // Moderation
  isPublic    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  
  @@index([weddingId])
}
