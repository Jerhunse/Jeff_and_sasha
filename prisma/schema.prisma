// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Authentication & User Management
// ============================================

enum Role {
  OWNER        // Couple getting married
  COLLABORATOR // Helpers (parents, wedding planner)
  VENDOR       // Photographers, caterers, etc.
  GUEST        // Wedding guests
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          Role      @default(GUEST)
  
  // Auth
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  
  // Relations
  coupleId      String?
  couple        Couple?   @relation(fields: [coupleId], references: [id])
  
  guestProfile  Guest?
  activityLogs  ActivityLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([email])
  @@index([coupleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Core Wedding/Couple Model
// ============================================

enum PrivacyMode {
  PUBLIC          // Anyone can view
  PASSWORD        // Requires password
  INVITE_ONLY     // Only guests with invite token
}

model Couple {
  id              String       @id @default(cuid())
  slug            String       @unique // URL slug (e.g., "jeff-and-sasha")
  
  // Basic Info
  partner1Name    String
  partner2Name    String
  weddingDate     DateTime
  venueName       String?
  venueAddress    String?
  venueCity       String?
  venueState      String?
  venueZip        String?
  venueCountry    String?
  
  // Theme & Branding
  primaryColor    String       @default("#6b9c7f")
  secondaryColor  String       @default("#f5f5f0")
  accentColor     String       @default("#d4a574")
  fontHeading     String       @default("Playfair Display")
  fontBody        String       @default("Inter")
  cornerRadius    String       @default("medium") // small, medium, large
  showFlorals     Boolean      @default(true)
  heroImageUrl    String?
  logoImageUrl    String?
  landingVideoUrl String?      // Video URL for landing page animation
  
  // Privacy & Security
  privacyMode     PrivacyMode  @default(PUBLIC)
  sitePassword    String?      // Hashed password for PASSWORD mode
  isPublished     Boolean      @default(false)
  customDomain    String?      // e.g., "jeffandsasha.com"
  
  // Settings
  allowPlusOnes   Boolean      @default(true)
  rsvpDeadline    DateTime?
  maxCapacity     Int?         // Total venue capacity
  timezone        String       @default("America/New_York")
  
  // Integrations
  stripeAccountId String?      // Connected Stripe account for cash funds
  googleMapsApiKey String?     // For map embeds
  
  // Relations
  users           User[]
  guests          Guest[]
  households      Household[]
  addresses       Address[]
  tags            Tag[]
  pages           Page[]
  media           Media[]
  events          Event[]
  campaigns       Campaign[]
  invitations     Invitation[]
  rsvpQuestions   RSVPQuestion[]
  rsvpResponses   RSVPResponse[]
  hotels          HotelBlock[]
  registryLinks   RegistryLink[]
  cashFunds       CashFund[]
  faqs            Faq[]
  weddingParty    WeddingPartyMember[]
  contactMessages ContactMessage[]
  seatingCharts   SeatingChart[]
  messages        Message[]
  activityLogs    ActivityLog[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([slug])
  @@index([customDomain])
}

// ============================================
// Address Model
// ============================================

model Address {
  id              String      @id @default(cuid())
  coupleId        String
  couple          Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  line1           String
  line2           String?
  city            String
  state           String
  postal          String
  country         String      @default("US")
  
  // Relations
  households      Household[]
  guests          Guest[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([coupleId])
}

// ============================================
// CMS - Pages & Content
// ============================================

enum PageType {
  HOME
  STORY
  SCHEDULE
  TRAVEL
  REGISTRY
  FAQ
  GALLERY
  PARTY
  CONTACT
  CUSTOM
}

model Page {
  id          String    @id @default(cuid())
  coupleId    String
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  type        PageType
  slug        String    // e.g., "our-story", "travel", "schedule"
  title       String
  contentJSON String    // JSON structure of sections
  order       Int       @default(0)
  isPublished Boolean   @default(true)
  
  seo         PageSEO?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([coupleId, slug])
  @@index([coupleId])
  @@index([type])
}

model PageSEO {
  id              String   @id @default(cuid())
  pageId          String   @unique
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// Media Library
// ============================================

model Media {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  url         String
  thumbnailUrl String?
  filename    String
  mimeType    String
  size        Int      // bytes
  width       Int?
  height      Int?
  
  alt         String?
  caption     String?
  tags        String[] // Array of tags for filtering
  
  uploadedBy  String?  // User ID
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([coupleId])
  @@index([tags])
}

// ============================================
// Events & Schedule
// ============================================

enum EventVisibility {
  PUBLIC       // Visible to all guests
  PRIVATE      // Only specific tags
  INVITE_ONLY  // Must be explicitly invited
}

model Event {
  id              String           @id @default(cuid())
  coupleId        String
  couple          Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String           // "Ceremony", "Reception", "Rehearsal Dinner"
  description     String?
  startTime       DateTime
  endTime         DateTime?
  
  location        String?
  address         String?
  venue           String?
  
  attire          String?          // "Black Tie", "Cocktail", etc.
  visibility      EventVisibility  @default(PUBLIC)
  capacity        Int?             // Event-specific capacity
  
  // Relations
  rsvpQuestions   RSVPQuestion[]
  rsvpResponses   RSVPResponse[]
  seatingCharts   SeatingChart[]
  
  order           Int              @default(0)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([coupleId])
  @@index([startTime])
}

// ============================================
// Guest Management
// ============================================

enum RsvpStatus {
  PENDING
  YES
  NO
  MAYBE
}

model Household {
  id              String   @id @default(cuid())
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String   // e.g., "The Smith Family"
  
  // Address (optional reference)
  addressId       String?
  address         Address? @relation(fields: [addressId], references: [id])
  
  maxGuests       Int?     // Maximum allowed from this household
  notes           String?
  
  // Relations
  guests          Guest[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([coupleId])
  @@index([addressId])
}

model Guest {
  id              String    @id @default(cuid())
  coupleId        String
  couple          Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  userId          String?   @unique
  user            User?     @relation(fields: [userId], references: [id])
  
  // Basic Info
  firstName       String
  lastName        String
  email           String?
  phone           String?
  
  // Address (optional individual address)
  addressId       String?
  address         Address?  @relation(fields: [addressId], references: [id])
  
  // Household
  householdId     String?
  household       Household? @relation(fields: [householdId], references: [id])
  isPrimaryContact Boolean   @default(true)
  relationship    String?   // "spouse", "child", "parent"
  
  // Guest Details
  age             Int?
  isChild         Boolean   @default(false)
  isVIP           Boolean   @default(false)
  doNotContact    Boolean   @default(false)
  
  // Invitation
  inviteToken     String    @unique @default(cuid()) // Unique token for RSVP link
  invitedBy       String?   // Guest ID who invited them (for plus-ones)
  
  // Plus-One Policy
  allowPlusOne    Boolean   @default(false)
  plusOnePolicy   String    @default("none") // none, unnamed, named
  maxGuestsAllowed Int      @default(1) // Maximum number of guests allowed for this party (including primary guest)
  
  // Import tracking
  importSource    String?   // "csv", "google", "manual"
  importedAt      DateTime?
  originalData    String?   // JSON of original import data
  
  // CRM
  notes           String?
  importance      Int       @default(0)
  
  // Relations
  tags            GuestTag[]
  invitations     Invitation[]
  rsvpResponses   RSVPResponse[]
  seatingAssignments Seat[]
  activities      GuestActivity[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([coupleId])
  @@index([householdId])
  @@index([addressId])
  @@index([inviteToken])
  @@index([email])
  @@index([lastName])
}

// ============================================
// Tags & Groups
// ============================================

model Tag {
  id              String   @id @default(cuid())
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String
  color           String   @default("#6b9c7f")
  description     String?
  icon            String?  // lucide icon name
  
  isSystem        Boolean  @default(false)
  
  guests          GuestTag[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([coupleId, name])
  @@index([coupleId])
}

model GuestTag {
  id              String   @id @default(cuid())
  guestId         String
  guest           Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  tagId           String
  tag             Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  addedAt         DateTime @default(now())
  addedBy         String?  // User ID
  
  @@unique([guestId, tagId])
  @@index([guestId])
  @@index([tagId])
}

// ============================================
// Campaigns & Invitations
// ============================================

enum CampaignType {
  SAVE_THE_DATE
  INVITATION
  REMINDER
  UPDATE
  THANK_YOU
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

model Campaign {
  id              String         @id @default(cuid())
  coupleId        String
  couple          Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String         // Internal name
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  
  // Content
  subject         String?        // Email subject
  templateId      String?        // Reference to template
  customHTML      String?        // Custom HTML content
  customText      String?        // Plain text version
  smsMessage      String?        // SMS content
  
  // Targeting
  segmentJSON     String?        // JSON rules for segment (tags, status, etc.)
  
  // Scheduling
  scheduledAt     DateTime?
  sentAt          DateTime?
  
  // Stats
  totalRecipients Int            @default(0)
  sent            Int            @default(0)
  delivered       Int            @default(0)
  opened          Int            @default(0)
  clicked         Int            @default(0)
  bounced         Int            @default(0)
  failed          Int            @default(0)
  
  // Relations
  invitations     Invitation[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([coupleId])
  @@index([type])
  @@index([status])
  @@index([scheduledAt])
}

enum InvitationStatus {
  PENDING
  SCHEDULED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

model Invitation {
  id              String           @id @default(cuid())
  coupleId        String
  couple          Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  campaignId      String?
  campaign        Campaign?        @relation(fields: [campaignId], references: [id])
  
  guestId         String
  guest           Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  token           String           @unique @default(cuid()) // Unique token for tracking
  
  status          InvitationStatus @default(PENDING)
  
  // Delivery
  sentViaEmail    Boolean          @default(false)
  sentViaSMS      Boolean          @default(false)
  emailAddress    String?
  phoneNumber     String?
  
  // Tracking
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  repliedAt       DateTime?
  unsubscribedAt  DateTime?
  
  openCount       Int              @default(0)
  clickCount      Int              @default(0)
  
  // Metadata
  errorMessage    String?
  metadata        String?          // JSON for additional data
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@unique([campaignId, guestId])
  @@index([coupleId])
  @@index([campaignId])
  @@index([guestId])
  @@index([token])
  @@index([status])
}

// ============================================
// RSVP System
// ============================================

enum QuestionType {
  TEXT              // Free text
  TEXTAREA          // Long text
  SINGLE_SELECT     // Radio buttons
  MULTI_SELECT      // Checkboxes
  YES_NO            // Boolean
  MEAL_CHOICE       // Meal selection
  DIETARY           // Dietary restrictions
  PLUS_ONE          // Plus-one capture
  NUMBER            // Numeric input
  DATE              // Date picker
  EMAIL             // Email input
  PHONE             // Phone input
}

model RSVPQuestion {
  id              String       @id @default(cuid())
  coupleId        String
  couple          Couple       @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  eventId         String?      // Null = applies to all events
  event           Event?       @relation(fields: [eventId], references: [id])
  
  text            String       // Question text
  description     String?      // Help text
  type            QuestionType
  options         String[]     // For SELECT types
  placeholder     String?
  
  required        Boolean      @default(false)
  order           Int          @default(0)
  
  // Conditional visibility
  visibilityRule  String?      // JSON rule (e.g., show only for tag "Wedding Party")
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([coupleId])
  @@index([eventId])
  @@index([order])
}

model RSVPResponse {
  id              String     @id @default(cuid())
  coupleId        String
  couple          Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  guestId         String
  guest           Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  eventId         String?    // Null = general RSVP
  event           Event?     @relation(fields: [eventId], references: [id])
  
  status          RsvpStatus @default(PENDING)
  answersJSON     String?    // JSON object of question_id: answer
  
  message         String?    // Guest message/notes
  
  // Plus-one details (if applicable)
  plusOneName     String?
  plusOneEmail    String?
  plusOneAnswers  String?    // JSON for plus-one's answers
  
  respondedAt     DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@index([coupleId])
  @@index([guestId])
  @@index([eventId])
  @@index([status])
  @@unique([guestId, eventId])
}

// ============================================
// Seating Arrangements
// ============================================

model SeatingChart {
  id              String   @id @default(cuid())
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  eventId         String?
  event           Event?   @relation(fields: [eventId], references: [id])
  
  name            String   // e.g., "Reception", "Ceremony"
  description     String?
  
  tables          Table[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([coupleId])
  @@index([eventId])
}

model Table {
  id              String        @id @default(cuid())
  seatingChartId  String
  seatingChart    SeatingChart  @relation(fields: [seatingChartId], references: [id], onDelete: Cascade)
  
  name            String        // e.g., "Table 1", "Head Table"
  capacity        Int
  shape           String?       // "round", "rectangle", "oval"
  
  // Position on canvas
  x               Float?
  y               Float?
  
  seats           Seat[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([seatingChartId])
}

model Seat {
  id              String   @id @default(cuid())
  tableId         String
  table           Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  
  guestId         String
  guest           Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  seatNumber      Int?
  notes           String?  // e.g., "needs wheelchair access"
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([tableId, guestId])
  @@index([tableId])
  @@index([guestId])
}

// ============================================
// Hotels & Travel
// ============================================

model HotelBlock {
  id              String    @id @default(cuid())
  coupleId        String
  couple          Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  address         String?
  city            String?
  state           String?
  zip             String?
  phone           String?
  website         String?
  
  // Room Block Details
  code            String?   // Booking code
  startDate       DateTime?
  endDate         DateTime?
  deadline        DateTime? // Booking deadline
  specialRate     String?
  
  // Map
  mapPin          String?   // Lat,Lng for map marker
  distanceFromVenue String?
  amenities       String?
  
  order           Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([coupleId])
}

// ============================================
// Registry
// ============================================

model RegistryLink {
  id              String   @id @default(cuid())
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  label           String   // "Amazon", "Crate & Barrel"
  url             String
  description     String?
  imageUrl        String?
  
  order           Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([coupleId])
}

model CashFund {
  id              String               @id @default(cuid())
  coupleId        String
  couple          Couple               @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  imageUrl        String?
  
  goal            Float?               // Target amount
  received        Float                @default(0) // Amount received
  
  stripePriceId   String?              // Stripe Price ID
  isActive        Boolean              @default(true)
  
  contributions   CashFundContribution[]
  
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  
  @@index([coupleId])
}

model CashFundContribution {
  id              String   @id @default(cuid())
  cashFundId      String
  cashFund        CashFund @relation(fields: [cashFundId], references: [id], onDelete: Cascade)
  
  name            String
  email           String?
  message         String?
  
  amount          Float
  currency        String   @default("usd")
  stripePaymentId String?  @unique
  status          String   @default("pending") // pending, completed, failed
  
  createdAt       DateTime @default(now())
  
  @@index([cashFundId])
  @@index([stripePaymentId])
}

// ============================================
// FAQs
// ============================================

model Faq {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  question    String
  answer      String
  category    String?
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([coupleId])
}

// ============================================
// Wedding Party
// ============================================

enum WeddingPartyRole {
  BRIDE
  GROOM
  BRIDESMAID
  GROOMSMAN
  MAID_OF_HONOR
  BEST_MAN
  OFFICIANT
  FLOWER_GIRL
  RING_BEARER
  USHER
  READER
  OTHER
}

model WeddingPartyMember {
  id              String           @id @default(cuid())
  coupleId        String
  couple          Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name            String
  role            WeddingPartyRole
  roleLabel       String?          // Custom role label if OTHER
  bio             String?
  imageUrl        String?
  relationship    String?          // e.g., "Sister of the bride"
  
  order           Int              @default(0)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([coupleId])
}

// ============================================
// Messages & Communications
// ============================================

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Message {
  id              String        @id @default(cuid())
  coupleId        String
  couple          Couple        @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  subject         String
  bodyHTML        String
  bodyText        String?
  
  // Targeting
  segmentJSON     String?       // JSON rules for segment
  
  // Scheduling
  scheduledAt     DateTime?
  sentAt          DateTime?
  
  status          MessageStatus @default(DRAFT)
  
  // Stats
  totalRecipients Int           @default(0)
  sent            Int           @default(0)
  delivered       Int           @default(0)
  opened          Int           @default(0)
  failed          Int           @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([coupleId])
  @@index([status])
  @@index([scheduledAt])
}

// ============================================
// Contact Messages
// ============================================

model ContactMessage {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  name        String
  email       String
  phone       String?
  subject     String?
  message     String
  
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  
  @@index([coupleId])
  @@index([isRead])
}

// ============================================
// Activity Log
// ============================================

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  IMPORTED
  MERGED
  TAG_ADDED
  TAG_REMOVED
  RSVP_CHANGED
  INVITE_SENT
  NOTE_ADDED
  BULK_UPDATED
  MESSAGE_SENT
  SEATING_UPDATED
}

model ActivityLog {
  id              String         @id @default(cuid())
  coupleId        String
  couple          Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  
  actorId         String?        // User who performed the action
  actor           User?          @relation(fields: [actorId], references: [id])
  
  action          ActivityAction
  entityType      String?        // Guest, Event, Page, etc.
  entityId        String?        // ID of affected entity
  
  description     String
  meta            String?        // JSON metadata
  
  createdAt       DateTime       @default(now())
  
  @@index([coupleId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// Guest Activity (Specific to Guests)
// ============================================

model GuestActivity {
  id              String         @id @default(cuid())
  guestId         String
  guest           Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  action          ActivityAction
  description     String
  changes         String?        // JSON of what changed
  
  userId          String?        // Who made the change
  userName        String?
  
  canUndo         Boolean        @default(false)
  undoData        String?
  undoneAt        DateTime?
  undoneBy        String?
  
  createdAt       DateTime       @default(now())
  
  @@index([guestId])
  @@index([action])
  @@index([createdAt])
}

